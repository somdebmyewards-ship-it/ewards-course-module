APP_NAME="eWards Learning Hub"
APP_ENV=local
APP_KEY=
# Set to false for production
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
# Use "warning" for production, "debug" for development
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────────────────
# Create this database first: CREATE DATABASE ewards_learning;
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ewards_learning
DB_USERNAME=root
DB_PASSWORD=

# ── Cache, Queue, Session ────────────────────────────────────────
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=public
# Use "database" for production (requires jobs table migration)
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Email Configuration ──────────────────────────────────────────
# Gmail SMTP: Generate App Password at https://myaccount.google.com/apppasswords
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD="your-16-char-app-password"
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="your-email@gmail.com"
MAIL_FROM_NAME="eWards Learning Hub"

# Admin notification email - receives signup alerts
ADMIN_NOTIFICATION_EMAIL=admin@yourcompany.com

# ── AWS (Optional - for S3 file storage) ─────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Pusher (Optional - for real-time features) ───────────────────
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

# ── Frontend (Vite) ──────────────────────────────────────────────
VITE_API_URL="/api"
VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ── Smart Learning Assistant (Ask Ela) ───────────────────────────
# HuggingFace (embeddings - sentence similarity ranking)
# Get free token at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=hf_your_token_here
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── LLM - Groq (FREE, fast, high-quality answers) ───────────────
# 1. Go to https://console.groq.com (no credit card needed)
# 2. Create account > API Keys > Create new key
# 3. Paste the key below
GROQ_API_KEY=your_groq_key_here
GROQ_CHAT_MODEL=llama3-8b-8192
LLM_BASE_URL=https://api.groq.com/openai/v1

# ── AI Chunking & Retrieval Settings ─────────────────────────────
AI_CHUNK_SIZE=400
AI_CHUNK_OVERLAP=80
AI_MAX_CONTEXT_CHUNKS=5
AI_RATE_LIMIT_PER_MINUTE=15
AI_MIN_SIMILARITY_SCORE=0.20
