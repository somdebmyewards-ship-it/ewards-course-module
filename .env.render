# ─── Render Production Environment ───────────────────────────────
# Copy these as Environment Variables in Render Dashboard
# ─────────────────────────────────────────────────────────────────

APP_NAME="eWards Learning Hub"
APP_ENV=production
APP_KEY=              # Generate: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://your-render-app.onrender.com

LOG_CHANNEL=stack
LOG_LEVEL=warning

# ── Database (TiDB Cloud Serverless) ────────────────────────────
DB_CONNECTION=mysql
DB_HOST=gateway01.us-east-1.prod.aws.tidbcloud.com
DB_PORT=4000
DB_DATABASE=ewards_lms
DB_USERNAME=CjK9LE89HdBCPR8.root
DB_PASSWORD=          # Your TiDB password
MYSQL_ATTR_SSL_CA=/etc/ssl/certs/ca-certificates.crt

# ── Cache, Queue, Session ────────────────────────────────────────
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
FILESYSTEM_DISK=public

# ── CORS (your Vercel frontend URL) ─────────────────────────────
CORS_ALLOWED_ORIGINS=https://ewards-learning-hub.vercel.app

# ── Sanctum ──────────────────────────────────────────────────────
SANCTUM_TOKEN_EXPIRATION=480

# ── Email (optional) ────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@ewards.com
MAIL_FROM_NAME="eWards Learning Hub"
ADMIN_NOTIFICATION_EMAIL=admin@ewards.com

# ── AI Services (optional) ──────────────────────────────────────
HUGGINGFACE_API_TOKEN=
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama3-8b-8192
LLM_BASE_URL=https://api.groq.com/openai/v1
