# ─── Render Production Environment ───────────────────────────────
# Copy these as Environment Variables in Render Dashboard
# ─────────────────────────────────────────────────────────────────

APP_NAME="eWards Learning Hub"
APP_ENV=production
APP_KEY=              # Generate: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://your-render-app.onrender.com

LOG_CHANNEL=stack
LOG_LEVEL=warning

# ── Database (use Render MySQL or external like PlanetScale/Aiven) ──
DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
# OR use a single DATABASE_URL:
# DATABASE_URL=mysql://user:pass@host:3306/dbname

# ── Cache, Queue, Session ────────────────────────────────────────
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
FILESYSTEM_DISK=public

# ── CORS (your Vercel frontend URL) ─────────────────────────────
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

# ── Sanctum ──────────────────────────────────────────────────────
SANCTUM_TOKEN_EXPIRATION=480

# ── Email (optional) ────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@ewards.com
MAIL_FROM_NAME="eWards Learning Hub"
ADMIN_NOTIFICATION_EMAIL=admin@ewards.com

# ── AI Services (optional) ──────────────────────────────────────
HUGGINGFACE_API_TOKEN=
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama3-8b-8192
LLM_BASE_URL=https://api.groq.com/openai/v1
